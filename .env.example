# Database Configuration
# 로컬 개발/테스트용 SQLite
DATABASE_URL=postgresql://sellform:sellformpassword@localhost:5544/sellform_dev
# 운영/컨테이너용 PostgreSQL 예시
# DATABASE_URL=postgresql://sellform:sellformpassword@localhost:5432/sellform_dev

# Storage Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Security Settings
SELLFORM_RAG_DEBUG_ENABLED=false
SELLFORM_RAG_RUNTIME_MOCK=false

# Fact Extraction Controls
AI_FACT_EXTRACTION_TIMEOUT_SECONDS=30
AI_FACT_EXTRACTION_MAX_FACTS=20

# LLM Router Configuration (Sprint 18+)
SELLFORM_LLM_DEFAULT_PROVIDER=openai
SELLFORM_LLM_DEFAULT_MODEL=gpt-5.4-nano
SELLFORM_LLM_FALLBACK1_PROVIDER=google
SELLFORM_LLM_FALLBACK1_MODEL=gemini-2.5-flash
SELLFORM_LLM_FALLBACK2_PROVIDER=deterministic
SELLFORM_LLM_FALLBACK2_MODEL=local-rule-based
SELLFORM_LLM_ENABLE_FALLBACKS=true

# Generation & Agent Configuration (Sprint 48)
SELLFORM_GENERATION_MODE=mock
SELLFORM_TEXT_LLM_PRIMARY_PROVIDER=openai
SELLFORM_TEXT_LLM_PRIMARY_MODEL=gpt-5.4-nano
SELLFORM_TEXT_LLM_FALLBACK1_PROVIDER=gemini
SELLFORM_TEXT_LLM_FALLBACK1_MODEL=gemini-2.5-flash
SELLFORM_TEXT_LLM_FALLBACK2_PROVIDER=claude
SELLFORM_TEXT_LLM_FALLBACK2_MODEL=claude-3-5-sonnet-20241022
SELLFORM_TEXT_LLM_ENABLE_FALLBACKS=true
SELLFORM_IMAGE_PRIMARY_PROVIDER=openai


# LLM Web Browsing Collection (Sprint 23+)
SELLFORM_WEB_BROWSING_ENABLED=true
SELLFORM_WEB_BROWSING_PROVIDER=openai
SELLFORM_WEB_BROWSING_MODEL=gpt-5.4-nano
SELLFORM_WEB_BROWSING_TIMEOUT_SECONDS=30
SELLFORM_WEB_BROWSING_MAX_CHARS=12000
# URL 이미지 OCR은 멀티모달 호출 비용이 발생하므로 필요할 때만 활성화합니다.
SELLFORM_URL_OCR_ENABLED=false

# Backend export worker가 캡처할 canonical Next.js renderer origin.
SELLFORM_EXPORT_RENDER_BASE_URL=http://127.0.0.1:3000

# Optional Figma collaboration integration (Sprint 32 / 33)
# Keep disabled until a real MCP sender is configured.
SELLFORM_FIGMA_MCP_ENABLED=false
# Production must use a URL reachable by Figma, such as an HTTPS CDN origin.
SELLFORM_PUBLIC_ASSET_BASE_URL=http://localhost:8001
SELLFORM_FIGMA_BRIDGE_HOST=127.0.0.1
SELLFORM_FIGMA_BRIDGE_PORT=3417
SELLFORM_FIGMA_BRIDGE_URL=http://127.0.0.1:3417
SELLFORM_FIGMA_BRIDGE_TOKEN=
SELLFORM_FIGMA_BRIDGE_TIMEOUT_SECONDS=120
SELLFORM_FIGMA_MCP_URL=https://mcp.figma.com/mcp
SELLFORM_FIGMA_OAUTH_STORE_PATH=.sellform/figma-oauth.json
# The official Remote MCP OAuth callback must point to the local bridge.
SELLFORM_FIGMA_OAUTH_REDIRECT_URI=http://127.0.0.1:3417/oauth/callback

# Figma Plugin Importer (Sprint 34)
# Use a unique random value of at least 32 characters. Never commit the real value.
SELLFORM_FIGMA_PLUGIN_TICKET_SECRET=
SELLFORM_FIGMA_PLUGIN_TICKET_TTL_SECONDS=600
SELLFORM_FIGMA_PLUGIN_SESSION_TTL_SECONDS=600
SELLFORM_FIGMA_PLUGIN_PACKAGE_MAX_BYTES=20971520

# Legacy OpenAI fact model fallback.
# Sprint 18 이후에는 SELLFORM_LLM_DEFAULT_MODEL을 우선 사용합니다.
OPENAI_FACT_MODEL=gpt-4o-mini

# Provider API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Sprint 44.5 image generation provider
SELLFORM_IMAGE_PROVIDER=openai
SELLFORM_IMAGE_MODEL=gpt-image-1-mini
SELLFORM_IMAGE_PREVIEW_MODEL=gpt-image-1-mini
SELLFORM_IMAGE_OUTPUT_FORMAT=png

# Sprint 56 image generation configurations
SELLFORM_IMAGE_GENERATION_MODE=mock
SELLFORM_IMAGE_COST_APPROVAL_REQUIRED=true
SELLFORM_IMAGE_MAX_CANDIDATES_PER_SLOT=3
