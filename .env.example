# Database Configuration
# 로컬 개발 및 테스트 시에는 SQLite로 폴백 지원 (sqlite:///./sellform_dev.db)
DATABASE_URL=postgresql://sellform:sellformpassword@localhost:5432/sellform_dev

# Storage Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Security Settings
FACTORY_RAG_DEBUG_ENABLED=false
FACTORY_RAG_RUNTIME_MOCK=false
